---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="text-4xl font-bold py-4">Stefanus Ndaru's Personal Repository</h1>
			<p>
				Welcome to my personal repository. If you wish to learn more, please view my <a href="/blog">blog repository</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
